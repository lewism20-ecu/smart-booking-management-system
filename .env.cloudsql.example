# Local dev against Cloud SQL via proxy (make proxy + make cloud-dev)
# Copy to .env.cloudsql and fill in YOUR OWN values — never commit .env.cloudsql
# Proxy runs on 5434 to avoid conflict with local Docker Postgres on 5433
#
# DB_USER and DB_PASSWORD are personal — each developer uses their own Cloud SQL account.

GCP_CLOUDSQL_INSTANCE=cloud-computing-485217:us-east1:sbms-postgres

DB_NAME=smart_booking
DB_USER=your-cloudsql-username
DB_PASSWORD=your-cloudsql-password

JWT_SECRET=sbms-local-jwt-7f3c9a2d4b6e8f1a5c0d9e2b7a4f6c1d
JWT_EXPIRES_IN=1h
